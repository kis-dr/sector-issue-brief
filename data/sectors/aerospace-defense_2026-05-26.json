:[{"date":"2026-05-26","외인":22215826000,"개인":-22896417000,"기관":2376748000},{"date":"2026-05-22","외인":7564286000,"개인":-10486407000,"기관":2360535000},{"date":"2026-05-21","외인":11015483000,"개인":-16355093000,"기관":2931445000},{"date":"2026-05-20","외인":22046740000,"개인":-17411266000,"기관":-3722145000},{"date":"2026-05-19","외인":673099000,"개인":-769814000,"기관":73393000},{"date":"2026-05-18","외인":12762135000,"개인":-11434466000,"기관":-2073284000},{"date":"2026-05-15","외인":-26567788000,"개인":44683119000,"기관":-15765562000}]},{"code":"064350","name":"현대로템","market":"KSP","price":214000.0,"change_pct":3.88,"market_cap":23356450702000.0,"fwd_pe":16.75475,"fwd_pb":null,"has_chart":true,"has_new":true,"news":[{"id":"1710823060631851374","title":"'엔비디아맨' 또 수혈…현대차그룹, 자율주행·피지컬 AI 전환 가속도","summary":"그는 엔비디아에서 카메라 및 레이더 기반 장애물 인지 기술 개발을 담당했고, 박 대표는 현대차그룹 합류 직전까지 엔비디아 부사장을 지내며 자율주행 기술 개발과 상용화 과정을 주도했다.\n\n이번 인사를 계기로 현대차그룹은 자체 개발한 자율주행 기술 '아트리아 AI' 기술 고도화에 힘을 싣게 됐다.\n\n\"로보틱스, 피지컬 AI 기업으로 진화\" 현대차그룹은 올 초 박 대표 영입을 시작으로 자율주행과 로보틱스 부문 혁신을 위한 인사 영입과 조직 개편에 공을 들여왔다.","url":"https://www.hankookilbo.com/news/article/A2026052616120002860?did=NA","published_at":"2026-05-26T18:01:17","sentiment":"positive","is_new":true},{"id":"1710761289439121752","title":"현대로템, 피지컬 AI 국책과제 수주…차세대 무인전장 기술 선점 나서","summary":"현대로템이 피지컬 인공지능(AI) 기반 무인로봇 핵심 국책 개발 과제를 잇달아 따내며 미래 유무인 복합전투체계(MUM-T) 전장 기술 선점에 속도를 내고 있다.\n\n단순 무인 플랫폼 개발을 넘어 자연어 기반 통합 지휘통제와 디지털 트윈 시뮬레이션까지 확보하면서 AI 중심 미래 방산 체계 구축 경쟁에서 존재감을 키우는 모습이다.\n\n이번 과제를 통해 개발되는 통합 관제 시스템은 최소한의 운용 인력으로도 언어와 문자를 활용해 서로 다른 다수의 무인 플랫폼을 동시다발적으로 제어할 수 있다.","url":"https://www.ddaily.co.kr/page/view/2026052609265687536","published_at":"2026-05-26T13:56:00","sentiment":"positive","is_new":true},{"id":"1710824718921240615","title":"무인로봇 통합관제 시스템등 현대로템 국책과제 2건 수주","summary":"현대로템은 산업통상부 과제인 '자연어 명령 기반 이종·다중 로봇 통합 관제 시스템' 개발에 참여한다.\n\n이 과제는 다양한 무인 로봇을 사람의 언어와 문자 명령으로 통합 제어할 수 있는 관제 소프트웨어 구축이 핵심이다.\n\n현대로템은 해당 기술을 다목적 무인 차량 HR-셰르파와 다족보행 로봇(사진)에 적용해 군집 단위 운용이 가능한 통합 지휘통제체계를 구현할 계획이다.","url":