t.co.kr/industry/2026/05/11/2026051114473168949","published_at":"2026-05-11T17:20:00","sentiment":"positive","is_new":true},{"id":"1705380035801780593","title":"'램프 매각 반대' 현대모비스 자회사 노조, 사측과 합의…\"5년치 성과급에 격려금 5000만원\"","summary":"램프 사업부 매각 반대를 이유로 파업을 진행했던 현대모비스 자회사 유니투스 노사가 위로급 지급에 합의했다.\n\n11일 자동차 업계에 따르면 현대모비스의 램프 제조 자회사 중 한 곳인 유니투스 노사는 이날 지속성장 및 고용안정을 위한 합의서를 마련했다.\n\n현대모비스는 램프 사업부를 프랑스 OP모빌리티에 매각하는 절차를 진행 중이다.","url":"https://www.newsis.com/view/NISX20260511_0003624943","published_at":"2026-05-11T17:33:32","sentiment":"negative","is_new":true},{"id":"1705283474296017046","title":"현대모비스, 사무직 노조 출범…연쇄 매각 우려에 노조 결집","summary":"회사가 미래차 중심 사업 재편에 속도를 내는 가운데 노조는 고용 불안과 연쇄 사업부 매각 가능성을 우려하며 반발 수위를 높이는 분위기다.\n\n현대모비스 사무·연구직 노조는 지난달 공식 출범했다.\n\n노조는 OP모빌리티가 과거 인도 자동차 부품업체 바록 엔지니어링의 램프사업을 인수한 이후 일부 조직 재편과 인력 조정이 있었다는 점도 우려 요인으로 꼽고 있다.","url":"https://www.sidae.com/article/2026051108235921114","published_at":"2026-05-11T11:09:00","sentiment":"negative","is_new":true}],"disclosures":[{"date":"2026-05-11T15:44:40","title":"기업설명회(IR)개최(안내공시)              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260511800531","is_new":true}],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":923121739130.4299,"is_new":false,"series":[{"date":"2026-04-13","value":937827272727.27},{"date":"2026-04-15","value":940866666666.6699},{"date":"2026-04-21","value":940200000000.0},{"date":"2026-04-27","value":923158333333.3301},{"date":"2026-04-28","value":923352000000.0},{"date":"2026-04-29","value":923783333333.3301},{"date":"2026-05-06","value":923121739130.4299}]},"Y":{"period":"2026년","latest":3718720833333.33,"is_new":true,"series":[{"date":"2026-04-13","value":3764988000000.0},{"date":"2026-04-16","value":3762612000000.0},{"date":"2026-04-21","value":3766772000000.0},{"date":"2026-04-27","value":3739330769230.77},{"date":"2026-04-28","value":3734753846153.85},{"date":"2026-04-29","value":3720412000000.0},{"date":"2026-05-06","value":3718725000000.0},{"date":"2026-05-11","val