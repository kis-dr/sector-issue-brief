":true}],"disclosures":[],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":34700000000.0,"is_new":false,"series":[{"date":"2026-04-27","value":45200000000.0},{"date":"2026-05-06","value":41633333333.329994},{"date":"2026-05-08","value":37463636363.64},{"date":"2026-05-11","value":34700000000.0}]},"Y":{"period":"2026년","latest":161191666666.66998,"is_new":true,"series":[{"date":"2026-04-27","value":191860000000.0},{"date":"2026-05-06","value":185510000000.0},{"date":"2026-05-08","value":172141666666.66998},{"date":"2026-05-11","value":161175000000.0},{"date":"2026-05-20","value":161150000000.0},{"date":"2026-05-26","value":161191666666.66998}]}},"briefing":{"briefing":"주가 하락의 주요 원인은 최근 직원 개인 정보 유출 사건으로 인한 부정적인 영향으로 보입니다. 그러나 CJ ENM은 미국 PGA 투어에서 K-라이프스타일을 홍보하는 '하우스 오브 CJ'를 운영하며 글로벌 시장에서의 입지를 강화하고 있습니다.","content_url":"https://www.news1.kr/industry/distribution/6172266","article_title":"CJ, 美 PGA 투어서 '하우스 오브 CJ' 운영…비비고·올영·뚜쥬 총출동","change_rate":-0.84},"stk_flow":[{"date":"2026-05-26","외인":-730029000,"개인":1705129000,"기관":-980575000},{"date":"2026-05-22","외인":-246693000,"개인":12466000,"기관":297922000},{"date":"2026-05-21","외인":-1677901000,"개인":2272496000,"기관":-652725000},{"date":"2026-05-20","외인":-322392000,"개인":760398000,"기관":-458487000},{"date":"2026-05-19","외인":430845000,"개인":-527281000,"기관":122354000},{"date":"2026-05-18","외인":-1241762000,"개인":1393636000,"기관":-171737000},{"date":"2026-05-15","외인":-1660181000,"개인":1870789000,"기관":-269760000}]},{"code":"352820","name":"하이브","market":"KSP","price":236000.0,"change_pct":0.43,"market_cap":10172130764000.0,"fwd_pe":24.071224,"fwd_pb":null,"has_chart":true,"has_new":true,"news":[{"id":"1711031015289524483","title":"“아미가 만들어 낸 대상”…BTS, ‘아메리칸 뮤직 어워즈’ 대상 등 3관왕","summary":"군복무 이후 약 4년 만에 컴백한 그룹 방탄소년단이 아메리칸 뮤직 어워즈에서 대상 격인 올해의 아티스트 상을 포함해 3관왕을 달성했습니다.\n\n넷플릭스 애니메이션 '케이팝 데몬 헌터스'의 오리지널사운드트랙 '골든'은 올해의 노래를 품에 안았습니다.\n\n넷플릭스 애니메이션 '케이팝 데몬 헌터스'의 주제곡 '골든'은 '올해의 노래'를 가져갔습니다.","url":"https://news.kbs.co.kr/news/pc/view/view.do?nc