_cap":11280494788500.0,"fwd_pe":9.442049,"fwd_pb":null,"has_chart":true,"has_new":true,"news":[{"id":"1715987940439625776","title":"“여러분에 빚졌다” 옛정 잊지 않은 젠슨 황","summary":"엔비디아 뿌리 게임업계 광폭 행보 신제품 부재에 시장불만 잠재우기 젠슨 황 엔비디아 최고경영자(CEO)가 최근 방한 일정 중 T1 소속 프로게이머 ‘페이커’ 이상혁과 김택진 엔씨 대표, 장병규 크래프톤 의장 등 국내 게임 산업계 주요 인사들과 연달아 회동했다.\n\n전사적 역량이 인공지능(AI) 칩과 데이터센터 사업에 집중된 상황에서 황 CEO의 이번 행보는 엔비디아의 오랜 주력 사업이었던 게임 업계와의 유대감을 재확인하려는 상징적 제스처로 풀이된다.\n\n불과 5년 전만 해도 엔비디아의 핵심 사업은 ‘지포스’ 시리즈로 대표되는 게이밍 그래픽카드였다.","url":"https://www.kmib.co.kr/article/view.asp?arcid=1780910341&code=11161100","published_at":"2026-06-10T00:05:00","sentiment":"positive","is_new":true},{"id":"1715877974970077410","title":"크래프톤 장병규, 젠슨 황 회동 '펍지' 팬들에게 '치킨' 돌렸다","summary":"젠슨 황 회동 '펍지: 배틀그라운드' 팬 전원에게 기프티콘 보내 젠슨 황은 '지포스 RTX 5090'와 'RTX 스파크' 노트북 2대 선물 [서울=뉴시스]오동현 기자 = 장병규 크래프톤 의장이 'PUBG(펍지): 배틀그라운드' 팬들에게 한 '치킨 약속'을 지켰다.\n\n앞서 장 의장은 지난 7일 서울 강남구의 한 PC방에서 황 CEO와 회동하며 펍지 팬 이벤트를 열었다.\n\n엔비디아의 선물 공세에 장 의장도 즉석에서 화답했다.","url":"https://www.newsis.com/view/NISX20260609_0003662585","published_at":"2026-06-09T16:47:00","sentiment":"neutral","is_new":true}],"disclosures":[{"date":"2026-06-08T16:59:26","title":"최대주주등소유주식변동신고서              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260608800908","is_new":false},{"date":"2026-06-08T16:34:25","title":"주식등의대량보유상황보고서(일반)","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260608000348","is_new":false},{"date":"2026-06-08T16:19:24","title":"임원ㆍ주요주주특정증권등소유상황보고서","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260608000329","is_new":false},{"date":"2026-06-08T15:39:20","title":"[기재정정]최대주주등소유주식변동신고서              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260608800675","is_new":false},{"date":"2026-06-02T15:54:40","title":"자기주식처분결과보고서","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260602000301","is_new":false}],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":320794117647.06,"is_new":false,"series":[{"date":"2026-05-11","value":309133333333.32996}