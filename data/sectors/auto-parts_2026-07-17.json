:-484998000,"개인":-222254000,"기관":670088000},{"date":"2026-07-10","외인":706110000,"개인":-912653000,"기관":207422000},{"date":"2026-07-09","외인":2208988000,"개인":-1042130000,"기관":-1218372000},{"date":"2026-07-08","외인":1485292000,"개인":-908940000,"기관":-581141000}]},{"code":"012330","name":"현대모비스","market":"KSP","price":482000.0,"change_pct":-1.53,"market_cap":43733105006000.0,"fwd_pe":9.0429,"fwd_pb":null,"has_chart":true,"has_new":true,"news":[{"id":"1729462122032795657","title":"마이크론, 현대모비스 등에 차량용 메모리 장기 공급","summary":"미국 메모리 반도체 기업 마이크론이 현대모비스와 퀄컴 등 주요 자동차·반도체 기업들과 차량용 메모리 공급을 위한 장기 계약을 체결했습니다.\n\n산자이 메로트라 마이크론 최고경영자는 \"차량이 지능화할수록 메모리와 저장장치의 중요성이 커진다\"며, \"이번 협약이 더 안전하고 지능적인 차량 플랫폼을 구축하는 데 필요한 반도체를 안정적으로 확보하는 데 도움이 될 것\"이라고 밝혔습니다.\n\n마이크론은 삼성전자, SK하이닉스와 함께 세계 3대 메모리 반도체 업체로 꼽힙니다.","url":"https://news.kbs.co.kr/news/pc/view/view.do?ncd=8613269&ref=A","published_at":"2026-07-17T04:27:00","sentiment":"positive","is_new":true},{"id":"1729109168855585017","title":"현대모비스, 글로벌 배터리·전장부품 선도","summary":"현대모비스는 지난 3월 헝가리 케치케메트 지역에 신설한 모듈 공장을 본격 가동했다.\n\n현대모비스는 헝가리 공장에 전기차·하이브리드 차종용 섀시 모듈은 물론 내연차와 혼류 생산이 가능한 설비까지 구축했다.\n\n폭스바겐 전기차에 들어가는 BSA를 공급하는 스페인 신공장은 현대모비스가 유럽에 구축한 두 번째 글로벌 완성차 전용 공장이다.","url":"https://www.seoul.co.kr/news/economy/industry/2026/07/16/20260716039002","published_at":"2026-07-16T05:05:00","sentiment":"positive","is_new":true},{"id":"1729272668089356338","title":"현대모비스, 협력사와 SW 인재 육성…미래 모빌리티 생태계 구축","summary":"협력사 채용난 해소·미래차 대응 역량 강화 지원 신현우 기자 = 현대모비스(012330)가 협력사와의 상생협력 범위를 소프트웨어(SW) 인재육성 분야까지 확대하며 공급망 경쟁력 강화에 속도를 내고 있다.\n\n현대모비스는 지난해 취업준비생과 협력사 재직자를 대상으로 약 6개월 간의 심도 있는 모빌리티 소프트웨어 교육 과정을 운영해 '모비우스 부트캠프' 1기 수료생 270여 명을 배출했다.\n\n현대모비스 관계자는 \"협력사 단독으로 해결하기 힘든 문제를 함께 해결하는 방식으로 공급망 경쟁력 강화를 지원하고 있다\"고 설명했다.","url":"https://www.news1.kr/industry/general-industry/6230641","published_at":"2026-07-16T15:53:00","sentiment":"neutral","is_new":true}],"disclosures":[{"date":"2026-07-16T14:05:08","title":"사외이사의선임ㆍ해임또는중도퇴임에관한신고","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260716000412","is_new":true}],"reports":[{"broker":"iM증권","title":"본격적으로 공급망 구축에 나설 때","url":"https://ddi-cdn.deepsearch.com/research/company/2026/07/16/1729256128883331090/000-33c55077ab027c6a4643b6d4dc5943ca717cda46.pdf","date":"2026-07-16T14:50:17","summary":"iM증권은 현대모비스(012330)에 대해 매수 의견과 목표주가 580,000원을 유지했다. 26년 2분기 매출액 15.8조원(-0.3% YoY), 영업이익 8,580억원(-1.4% YoY)을 전망하며, 안전공업 화재에 따른 국내 완성차 출하량 감소와 반도체 가격 상승 부담이 있으나 환율 상승 및 관세 인하 효과로 AS사업부 이익 기여도 증가와 전동화사업부 적자 축소가 예상된다. 핵심 투자 포인트는 Boston Dynamics에 액츄에이터 공급 공식화 및 2028년 연 3만대 CAPA 공장 건설 계획 등 휴머노이드 로봇 공급망 구축 잠재 가치다.","key_points":["26년 2분기 매출액 15.8조원(-0.3% YoY), 영업이익 8,580억원(-1.4% YoY) 전망 - 안전공업 화재로 인한 완성차 출하 감소 및 반도체 비용 부담 존재하나, 환율 상승·관세 인하 효과로 AS사업부 이익 기여 증가 및 전동화 적자 축소 예상","Boston Dynamics에 액츄에이터 공급 공식화(CES 2026), 2028년 연 3만대 CAPA 공장 건설 계획 유지 및 외부 레거시 OEM 판매 가능성 시사 - 휴머노이드 로봇 공급망 구축이 밸류에이션 상방 요인","목표주가 580,000원 유지(현재가 489,500원 대비 상승여력 18.5%) - 경쟁 글로벌 Tier 1 대비 액츄에이터 사업 진출 의지 및 Boston Dynamics 캡티브 매출처 확보에 근거한 Target Multiple 적용"],"is_new":true},{"broker":"유진투자증권","title":"2Q26 Preview: 기대치 부합할 실적,   본격 개선은 하반기로","url":"https://ddi-cdn.deepsearch.com/research/company/2026/07/10/1726982550292926466/000-152c15c562c345faa9c021ec1dbe1f8880bb118c.pdf","date":"2026-07-10T08:15:53","summary":"유진투자증권은 현대모비스(012330)에 대해 투자의견 BUY를 유지하되 목표주가를 91만원에서 74만원으로 하향 조정했다. 2Q26 실적은 매출액 16.8조원(+5.4%yoy), 영업이익 8,710억원(+0.1%yoy)으로 컨센서스에 부합할 전망이다. A/S 부문은 역대 최고 마진율을 유지하는 반면 차부품 부문은 전기차 시장 위축, 원자재 가격 상승 등으로 부진이 지속되고 있다. 하반기에는 북미 하이브리드 양산 효과, 아이오닉3 유럽 출시, VW향 신규 매출 등으로 본격 개선이 기대되며, 로보틱스 관련 BD향 핵심 부품 공급사 확정으로 성장 모멘텀도 유효하다.","key_points":["2Q26 실적은 매출액 16.8조원(+5.4%yoy), 영업이익 8,710억원(+0.1%yoy), 지배이익 1조원(+12.3%yoy)으로 컨센서스 부합 전망. A/S 부문의 역대 최고 수준 이익률이 실적을 견인","차부품 부문은 미국 전기차 시장 위축, 원자재 가격 상승, 국내·인도 생산 차질로 부진 지속. 하반기 북미 하이브리드 양산 효과, 아이오닉3 유럽 출시, VW향 신규 매출로 전동화 부문 개선 기대","BD향 액츄에이터 및 핵심 부품 공급사로 확정된 로보틱스 모멘텀 유효. 현대차 등 관련주 밸류에이션 하락을 반영해 목표주가를 기존 91만원에서 74만원으로 23% 하향 조정"],"is_new":false},{"broker":"LS증권","title":"실적 좋고 로보틱스는 순항 중","url":"https://ddi-cdn.deepsearch.com/research/company/2026/07/09/1726633145387847693/000-86fb7fbd2695cb630110ed859508ec7726ce4d3f.pdf","date":"2026-07-09T09:07:29","summary":"LS증권은 현대모비스(012330)에 대해 투자의견 Buy와 목표주가 870,000원을 유지했다. 2Q26 매출액 16.2조원(+1.6% YoY), 영업이익 9,867억원(+13.4% YoY)으로 컨센서스를 상회할 전망이다. AS부문의 고수익성 유지와 관세 영향 축소, 로보틱스 사업 내 HW 입지 강화가 긍정적 요인으로 꼽혔다. 미국 현지 액추에이터 공장(연산 35만대) 확보 계획으로 로봇 부품사로의 Re-rating이 기대되며, 아틀라스 3만대 양산 시 액추에이터 매출 1.5조원 이상이 예상된다. 현재 주가는 12M Fwd P/E 10.0배로 저평가 구간으로 판단, 업종 내 Top Pick을 유지한다.","key_points":["2Q26 영업이익 9,867억원(+13.4% YoY, +22.9% QoQ, OPM 6.1%) 예상으로 컨센서스 대비 8.4% 상회 전망. AS부문 영업이익 9,440억원(OPM 26.5%), 관세 영향 850억→500억 수준으로 축소","미국 현지 연산 35만대 규모 액추에이터 공장 확보 계획, 초기 매출 효과 약 3,500억원 추정. 아틀라스 3만대 양산 시 액추에이터 매출 1.5조원 이상 기대되며 로봇 부품사로의 Re-rating 전망","현재 주가 488,500원은 12M Fwd P/E 10.0배로 저평가 구간 판단. 목표주가 870,000원 대비 상승여력 78.1%, 업종 내 Top Pick 유지"],"is_new":false}],"consensus":{"Q":{"period":"2026년 3분기","latest":964658333333.3301,"is_new":false,"series":[{"date":"2026-06-16","value":952600000000.0},{"date":"2026-06-24","value":949433333333.3301},{"date":"2026-07-02","value":951266666666.6699},{"date":"2026-07-06","value":952529166666.6699},{"date":"2026-07-07","value":953654166666.6699},{"date":"2026-07-08","value":955029166666.6699},{"date":"2026-07-09","value":959578260869.5701},{"date":"2026-07-10","value":964839130434.78},{"date":"2026-07-14","value":964208333333.3301},{"date":"2026-07-15","value":964658333333.3301}]},"Y":{"period":"2026년","latest":3733428000000.0,"is_new":true,"series":[{"date":"2026-06-16","value":3719040000000.0},{"date":"2026-06-24","value":3716560000000.0},{"date":"2026-07-02","value":3720880000000.0},{"date":"2026-07-06","value":3715444000000.0},{"date":"2026-07-07","value":3713804000000.0},{"date":"2026-07-08","value":3716284000000.0},{"date":"2026-07-09","value":3720324000000.0},{"date":"2026-07-10","value":3723484000000.0},{"date":"2026-07-14","value":3735484000000.0},{"date":"2026-07-15","value":3733572000000.0},{"date":"2026-07-16","va