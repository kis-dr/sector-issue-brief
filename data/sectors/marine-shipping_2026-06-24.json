ge_pct":-4.91,"market_cap":17534793862300.0,"fwd_pe":15.60866,"fwd_pb":null,"has_chart":true,"has_new":true,"news":[{"id":"1721213220934520968","title":"HMM 선박 2척 호르무즈 해협 통과…유조선 1척 국내로","summary":"▲ HMM의 1만 6천TEU급 컨테이너선 다온호 HMM 선박 2척이 호르무즈 해협을 무사히 빠져나왔습니다.\n\nHMM은 1만 6천TEU급 컨테이너선 다온호와 유조선 유니버설글로리호가 호르무즈 해협을 안전하게 벗어나 운항 중이라고 오늘(24일) 밝혔습니다.\n\nHMM은 호르무즈해협에 유조선 2척, 벌크 화물선 2척, 컨테이너선 1척 등 총 5척이 묶였다가, 피격당해 두바이에서 수리 중인 나무호를 포함해 벌크 화물선 2척만 호르무즈 해협 내에 남아있습니다.","url":"https://news.sbs.co.kr/news/endPage.do?news_id=N1008624937","published_at":"2026-06-24T10:09:03","sentiment":"positive","is_new":true},{"id":"1721220814902268385","title":"韓 선박 4척 호르무즈 해협 통과…종전 MOU 이후 6척째","summary":"한국 국적 선박 4척이 추가로 호르무즈 해협을 벗어났다.\n\n해양수산부는 호르무즈 해협 내측에서 대기 중이던 한국 국적 선박 4척이 해협을 통과해 정상 항해 중이라고 24일 밝혔다.\n\n이에 따라 호르무즈 해협 내 한국 국적 선박은 18척으로 줄었고 선원 수 또한 108명으로 감소했다.","url":"https://www.kmib.co.kr/article/view.asp?arcid=0030013020&code=61141111","published_at":"2026-06-24T10:39:08","sentiment":"positive","is_new":true}],"disclosures":[],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":280876923076.92,"is_new":true,"series":[{"date":"2026-05-26","value":266950000000.0},{"date":"2026-05-27","value":266866666666.66998},{"date":"2026-06-08","value":269450000000.0},{"date":"2026-06-23","value":280876923076.92}]},"Y":{"period":"2026년","latest":1037715384615.38,"is_new":true,"series":[{"date":"2026-05-26","value":1011858333333.3301},{"date":"2026-05-27","value":1011941666666.6699},{"date":"2026-06-08","value":1029358333333.3301},{"date":"2026-06-23","value":1037715384615.38}]}},"briefing":{"briefing":"이번 하락은 이란 해협 통항 신청과 관련된 보험료 부담이 주요 원인으로 작용한 것으로 보입니다. 또한, 글로벌 물류 시장 공략을 위한 특수화물 전시회 참가 소식이 있었으나, 시장 반응은 부정적이었습니다.","content_url":"https://www.mk.co.kr/article/12078383","article_title":"HMM, 이란에 호르무즈 통항 신청…실제 운항은 보험료가 변수","change_rate":-4.91},"stk_flow":[{"date":"2026-06-23","외인":-6652972000,"개인":8768896000,"기관":-1714171000},{"date":"2026-06-22","외인":-3185524000,"개인":7500836000,"기관":-4175994000},{"da