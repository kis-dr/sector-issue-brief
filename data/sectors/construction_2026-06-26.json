-7473870000,"기관":11399409000},{"date":"2026-06-19","외인":18760561000,"개인":-30764517000,"기관":12530510000},{"date":"2026-06-18","외인":-273072000,"개인":10585451000,"기관":-11112952000},{"date":"2026-06-17","외인":-46829937000,"개인":83178263000,"기관":-33913838000}]},{"code":"375500","name":"DL이앤씨","market":"KSP","price":61900.0,"change_pct":0.0,"market_cap":2395135263700.0,"fwd_pe":5.6033397,"fwd_pb":null,"has_chart":true,"has_new":true,"news":[{"id":"1721659164519960874","title":"DL이앤씨, 8년 연속 'AA-' 신용등급 유지","summary":"또한 주택 부문 원가율 개선에 따른 수익성 회복세와 원활한 현금창출력, 우수한 재무안정성을 높게 평가했다.\n\n수익성이 우수한 사업장의 매출 비중 확대와 원가율 개선에 힘입어 향후에도 우수한 영업수익성을 이어갈 것으로 전망했다.\n\nDL이앤씨 재무관리실 관계자는 “이번 신용등급 평가를 통해 우수한 사업경쟁력과 안정적인 사업기반, 업계 최고 수준의 재무안정성을 다시 한번 인정받았다”며 “수익성 중심의 내실경영과 철저한 리스크 관리를 바탕으로 안정적인 실적 개선과 기업가치 제고를 지속해 나갈 것”이라고 밝혔다.","url":"https://news.tvchosun.com/site/data/html_dir/2026/06/25/2026062590206.html","published_at":"2026-06-25T15:37:00","sentiment":"positive","is_new":true},{"id":"1721596785136373882","title":"DL그룹 ‘에너지 인프라 디벨로퍼’로 글로벌 공략","summary":"원전·SMR 포함 에너지 밸류체인 구축 미국내 유일 韓 민간에너지 디벨로퍼 에너지 수요 증가에 따라 원전·에너지 인프라 투자 확대 기대감이 큰 가운데, 국회에서 ‘대미투자특별법’ 이 통과되면서 미국 시장에서 경쟁력을 갖춘 국내 기업으로 관심이 쏠리고 있다.\n\n25일 관련 업계에 따르면 DL그룹은 사업 개발 및 금융조달·운영을 담당하는 DL에너지, 국내외 플랜트 외 원전 설계·조달·시공(EPC) 수행 역량을 갖춘 DL이앤씨를 축으로 하는 에너지 사업 포트폴리오를 보유하고 있다.\n\nDL에너지는 국내에서 유일하게 현재 미국에서 가스복합 발전소를 투자, 운영하는 민간 에너지 디벨로퍼다.","url":"https://biz.heraldcorp.com/article/10788015","published_at":"2026-06-25T11:33:00","sentiment":"positive","is_new":true}],"disclosures":[{"date":"2026-06-22T18:28:36","title":"벌금등의부과              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260622800877","is_new":false}],"reports":[{"broker":"iM증권","title":"사우디의 무리한 과세 통보, 현실화 가능성은 낮음","url":"https://ddi-cdn.deepsearch.com/research/company/2026/06/24/1721202410728329216/000-fb6b7625433e5ce745f28bf99c9929406919b3e3.pdf","date":"2026-06-24T09:27:41","summary":"iM증권은 DL이앤씨에 대해 사우디 과세당국(ZATCA)으로부터 통보받은 8,533억원 규모의 법인세 및 가산세 부과가 실제 납부로 이어질 가능성이 낮다고 판단했다. DL이앤씨의 불복 주장은 한-사우디 조세조약 및 사우디 소득세법에 근거해 타당성이 충분하며, 이중과세 문제, 제척기간 경과, 과세 산출 근거 부족 등 세 가지 핵심 논거를 바탕으로 추징세액이 대폭 감소할 가능성이 높다고 분석했다. 투자의견 Buy, 목표주가 120,000원을 유지했다.","key_points":["사우디 과세당국(ZATCA)이 DL이앤씨에 2006~2019년 EPC 수행 관련 법인세 및 가산세 8,533억원(자기자본 대비 16.27%) 부과 통보","DL이앤씨의 불복 근거: ①한-사우디 조세조약상 이중과세 소지, ②10년 제척기간 경과(2006~2015년 프로젝트 제외 시 세액 160억원대로 감소), ③과세 산출 근거 부족","조세 심판 과정 또는 과세당국 간 합의를 통해 추징세액 대폭 감소 가능성 높으며, 대규모 충당부채 인식 가능성도 낮다고 판단"],"is_new":false}],"consensus":{"Q":{"period":"2026년 2분기","latest":119431250000.0,"is_new":false,"series":[{"date":"2026-05-26","value":118966666666.67},{"date":"2026-06-12","value":120166666666.67},{"date":"2026-06-16","value":120193333333.33},{"date":"2026-06-19","value":119431250000.0}]},"Y":{"period":"2026년","latest":505444444444.44,"is_new":false,"series":[{"date":"2026-05-26","value":507800000000.0},{"date":"2026-06-10","value":507175000000.0},{"date":"2026-06-12","value":509237500000.0},{"date":"2026-06-16","value":509729411764.71},{"date":"2026-06-19","value":505444444444.44}]}},"briefing":{"briefing":"이번 주가는 사우디아라비아의 법인세 부과 통지와 관련된 우려에도 불구하고 큰 변동이 없었던 것으로 보입니다. 그러나 신용등급 유지와 수익성 회복에 대한 긍정적인 평가가 있었음을 알 수 있습니다.","content_url":"https://news.tvchosun.com/site/data/html_dir/2026/06/25/2026062590206.html","article_title":"DL이앤씨, 8년 연속 'AA-' 신용등급 유지","change_rate":0.0},"stk_flow":[{"date":"2026-06-25","외인":6517229000,"개인":-5293762000,"기관":-522085000},{"date":"2026-06-24","외인":8668665000,"개인":-9082779000,"기관":193825000},{"date":"2026-06-23","외인":12347431000,"개인":3138369000,"기관":-16446494000},{"date":"2026-06-22","외인":27138000,"개인":-585351000,"기관":214164000},{"date":"2026-06-19","외인":13095373000,"개인":-15173626000,"기관":2058468000},{"date":"2026-06-18","외인":6303727000,"개인":-95027000,"기관":-6218848000},{"date":"2026-06-17","외인":-34616391000,"개인":38760267000,"기관":-3337117000}]}],"market_data":{"charts":[{"title":"미국 10Y 금리","unit":"%","last_date":"2026-06-25","last_val":4.39,"prev_val":4.45,"chg":-0.06,"chg_pct":-1.33,"series":[{"d":"2026-05-26","v":4.