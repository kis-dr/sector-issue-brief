hange_pct":-0.59,"market_cap":23921313208000.0,"fwd_pe":5.9378667,"fwd_pb":null,"has_chart":true,"has_new":true,"news":[{"id":"1731081354503917655","title":"케이퓨얼셀, 차세대 잠수함용 연료전지 개발 나선다","summary":"113억원 규모 국책과제 주관기관 선정 2029년까지 20㎾급 시스템 개발 [헤럴드경제=권제인 기자] 코렌스 그룹 계열사인 케이퓨얼셀이 차세대 잠수함용 연료전지 시스템 개발에 나선다고 21일 밝혔다.\n\n케이퓨얼셀은 2029년 12월까지 국산 잠수함용 연료전지 기술 고도화에 나선다.\n\n케이퓨얼셀 관계자는 “이번 정부과제 주관기관 선정은 케이퓨얼셀의 연료전지 시스템 통합 및 제어 기술력이 국가 해양 방위산업의 미래를 이끌 핵심 기술로 인정받았다는 점에서 의미가 크다”며 “HD한국조선해양 등 파트너들과 긴밀한 협력 체계를 구축하고, 기존 AIP 체계를 한 단계 더 발전시켜 안전성과 운용 효율성, 경제성을 높인 차세대 해양 연료전지 시스템을 성공적으로 선보이겠다”고 밝혔다.","url":"https://biz.heraldcorp.com/article/10815253","published_at":"2026-07-21T15:41:00","sentiment":"positive","is_new":true}],"disclosures":[{"date":"2026-07-20T16:01:23","title":"생산중단(자회사의 주요경영사항)              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260720800436","is_new":false},{"date":"2026-07-20T08:40:29","title":"중대재해발생(자회사의 주요경영사항)              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260720800051","is_new":false},{"date":"2026-07-16T15:50:16","title":"영업(잠정)실적(공정공시)              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260716800643","is_new":false},{"date":"2026-07-16T15:50:16","title":"영업(잠정)실적(공정공시)(자회사의 주요경영사항)              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260716800632","is_new":false}],"reports":[],"consensus":{"Q":{"period":"2026년 3분기","latest":1450460000000.0,"is_new":false,"series":[{"date":"2026-06-22","value":1395770000000.0},{"date":"2026-06-23","value":1406270000000.0},{"date":"2026-07-13","value":1426633333333.3298},{"date":"2026-07-15","value":1450460000000.0}]},"Y":{"period":"2026년","latest":5796925000000.0,"is_new":false,"series":[{"date":"2026-06-22","value":5599328571428.569},{"date":"2026-06-23","value":5626400000000.0},{"date":"2026-07-02","value":5643046153846.15},{"date":"2026-07-09","value":5641775000000.0},{"date":"2026-07-13","value":5696300000000.0},{"date":"2026-07-15","value":5796925000000.0}]}