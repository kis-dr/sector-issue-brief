_pb":null,"has_chart":true,"has_new":true,"news":[{"id":"1716155465420902609","title":"[K조선업, 사라진 숙련공]①18년째 시급 2만원…\"조선업, 누가 일하겠나\"","summary":"18년 전이나 지금이나, 시급 2만원대 문제는 단순한 인력 부족을 넘어 숙련 인력 구조 자체가 흔들리고 있다는 점이다.\n\n이은창 산업연구원 연구위원은 \"외국인 인력 활용은 필요하지만 핵심은 숙련화 시스템\"이라며 \"젊은 인력이 현장에 들어와 숙련공으로 성장하는 구조 자체를 복원하지 못하면 기술 전수 단절 문제는 계속될 수밖에 없다\"고 말했다.\n\n그는 \"조선업은 자동화가 쉽지 않은 산업이기 때문에 결국 사람의 숙련도가 경쟁력\"이라며 \"생산가능인구 감소까지 겹치면서 현장 인력 기반 자체가 약해지고 있다\"고 덧붙였다.","url":"https://view.asiae.co.kr/article/2026060915251603914","published_at":"2026-06-10T11:10:00","sentiment":"negative","is_new":true}],"disclosures":[{"date":"2026-06-08T10:58:52","title":"단일판매ㆍ공급계약체결(자율공시)              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260608800378","is_new":false}],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":993329411764.71,"is_new":false,"series":[{"date":"2026-05-11","value":966425000000.0},{"date":"2026-05-12","value":988787500000.0},{"date":"2026-05-26","value":992475000000.0},{"date":"2026-05-27","value":993329411764.71}]},"Y":{"period":"2026년","latest":3864368421052.63,"is_new":false,"series":[{"date":"2026-05-11","value":3781455555555.56},{"date":"2026-05-12","value":3837477777777.7803},{"date":"2026-05-21","value":3838533333333.33},{"date":"2026-05-26","value":3816294736842.1104},{"date":"2026-05-27","value":3824830000000.0},{"date":"2026-05-28","value":3824850000000.0},{"date":"2026-05-29","value":3864368421052.63}]}},"briefing":{"briefing":"이 상승은 필리핀에서 HD현대중공업이 건조한 원해경비함의 취역식 소식과 관련이 있습니다. 또한, VLGC 2척 수주 계약 체결 소식도 긍정적인 영향을 미친 것으로 보입니다.","content_url":"https://www.yna.co.kr/view/AKR20260609153100084?input=1195m","article_title":"'HD현대중공업 건조' 필리핀 원해경비함 2번함 취역","change_rate":4.74},"stk_flow":[{"date":"2026-06-10","외인":20166515000,"개인":-34244736000,"기관":13934293000},{"date":"2026-06-09","외인":-9740235000,"개인":18791650000,"기관":-9720342000},{"date":"2026-06-08","외인":0,"개인":0,"기관":0},{"date":"2026-06-05","외인":36481643000,"개인":-44527987000,"기관":8610738000},{"date":"202