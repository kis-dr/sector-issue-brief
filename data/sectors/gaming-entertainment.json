9억원, 영업이익 1435억원, 당기순이익 1104억원을 거둘 것으로 예측되고 있다.\n\n1분기 실적 전망치는 '검은사막'의 직접 서비스 전환 및 '검은사막 모바일'의 국내외 흥행이 맞물리며 역대 최대 실적을 달성한 2019년 2분기 매출 1523억원, 영업이익 569억원 보다 2배 높은 성과이기도 하다.","url":"http://www.inews24.com/view/1966599","published_at":"2026-05-08T08:19:00","sentiment":"positive","is_new":true}],"disclosures":[],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":112400000000.0,"is_new":false,"series":[{"date":"2026-04-08","value":104700000000.0},{"date":"2026-04-29","value":112400000000.0}]},"Y":{"period":"2026년","latest":316014285714.29004,"is_new":false,"series":[{"date":"2026-04-08","value":293566666666.67004},{"date":"2026-04-10","value":289800000000.0},{"date":"2026-04-29","value":316014285714.29004}]}},"stk_flow":[{"date":"2026-05-08","외인":-1022984000,"개인":4476993000,"기관":-3536417000},{"date":"2026-05-07","외인":-2520292000,"개인":3664758000,"기관":-1137098000},{"date":"2026-05-06","외인":-4136704000,"개인":6949659000,"기관":-2755643000},{"date":"2026-05-04","외인":794234000,"개인":1084057000,"기관":-1934212000},{"date":"2026-04-30","외인":5786084000,"개인":-6253014000,"기관":573589000},{"date":"2026-04-29","외인":5427525000,"개인":-5999370000,"기관":516417000},{"date":"2026-04-28","외인":6725761000,"개인":-5127460000,"기관":-1386600000}]},{"code":"052770","name":"아이톡시","market":"KSQ","price":312.0,"change_pct":0.0,"market_cap":4545457488.0,"fwd_pe":null,"fwd_pb":null,"has_chart":true,"has_new":true,"news":[],"disclosures":[{"date":"2026-05-08T07:31:30","title":"[기재정정]소액공모공시서류(지분증권)","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260507000782","is_new":true},{"date":"2026-05-07T14:49:38","title":"[기재정정]주요사항보고서(유상증자결정)","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260507000450","is_new":false}],"reports":[],"consensus":{"Q":{},"Y":{}},"stk_flow":[{"date":"2026-05-08","외인":0,"개인":0,"기관":0},{"date":"2026-05-07","외인":0,"개인":0,"기관":0},{"date":"2026-05-06","외인":0,"개인":0,"기관":0},{"date":"2026-05-04","외인":0,"개인":0,"기관":0},{"date":"2026-04-30","외인":0,"개인":0,"기관":0},{"date":"2026-04