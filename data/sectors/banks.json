6083/000-a41fa6dfb4a0b792b405c9c39cce2f3a7386d24e.pdf","date":"2026-04-29T10:02:10","summary":"대신증권은 우리금융지주(316140)에 대해 투자의견 매수(BUY)와 목표주가 43,000원을 유지했다. 1Q26 실적은 거액 충당금과 판관비 증가로 컨센서스를 하회했으나, CET1비율이 전분기 대비 70bp 상승한 13.6%를 기록하며 자본안정성을 입증했다. 유형자산재평가로 1.8조원 이익이 반영된 영향이 크다. 우리투자증권 증자 1조원, 동양생명 완전자회사화 등 비은행 계열사 강화가 진행 중이며, 2026년 DPS 1,510원(YoY +11%), 비과세 배당 감안 시 실질 배당금 증가율 19.1%로 커버리지 금융지주 중 최고 배당수익률이 기대된다.","key_points":["1Q26 CET1비율 13.6% 달성(전분기 대비 +70bp): 유형자산재평가로 세후 1.8조원 이익 반영, 커버리지 금융지주 중 두 번째로 높은 자본안정성 확보","2026년 DPS 1,510원(YoY +11%) 전망, 비과세 배당 효과 감안 시 실질 증가율 19.1%로 커버리지 금융지주 중 최고 배당수익률(4.5%) 예상","우리투자증권 증자 1조원 및 동양생명 완전자회사화 공시로 비은행 계열사 강화 가속화, CET1비율 영향 없이 진행되며 총환원율 50%까지 상승 가능"],"is_new":false}],"consensus":{"Q":{"period":"2026년 2분기","latest":1307500000000.0,"is_new":false,"series":[{"date":"2026-04-06","value":1284428571428.57},{"date":"2026-04-08","value":1281375000000.0},{"date":"2026-04-16","value":1281125000000.0},{"date":"2026-04-27","value":1307500000000.0}]},"Y":{"period":"2026년","latest":4346433333333.33,"is_new":false,"series":[{"date":"2026-04-06","value":4565306250000.0},{"date":"2026-04-08","value":4563431250000.0},{"date":"2026-04-16","value":4555618750000.0},{"date":"2026-04-17","value":4561868750000.0},{"date":"2026-04-27","value":4346433333333.33}]}},"stk_flow":[{"date":"2026-05-06","외인":-30419452000,"개인":18455758000,"기관":-28028055000},{"date":"2026-05-04","외인":-22767035000,"개인":4892863000,"기관":-1009894000},{"date":"2026-04-30","외인":-23884609000,"개인":-7513468000,"기관":17226295000},{"date":"2026-04-29","외인":-7840054000,"개인":-306602000,"기관":-5318163000},{"date":"2026-04-28","외인":-9268815000,"개인":-9573896000,"기관":7890169000},{"date":"2026-04-27","외인":-107133316000,"개인":108637078000,"기관":-34687077000},{"date":"2026-04-24","외인":-7349594000,"개인":2194852000,"기관":5061108000}]},{"code":"139130","name":"iM금융지주","market":"KSP","price":18980.0,"change_pct":-1.66,"market_cap":3048654585340.0,"fwd_pe":5.5678406,"has_chart":true,"has_new":false,"news":[],"disc