반발 속에서, 대구시의 막바지 발품 홍보가 어떤 성과로 이어질지 주목됩니다.","url":"https://news.kbs.co.kr/news/pc/view/view.do?ncd=8555872&ref=A","published_at":"2026-05-08T08:19:44","sentiment":"neutral","is_new":true}],"disclosures":[],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":965500000000.0,"is_new":false,"series":[{"date":"2026-04-08","value":979166666666.6699},{"date":"2026-04-16","value":973333333333.3301},{"date":"2026-04-27","value":967500000000.0},{"date":"2026-04-28","value":971111111111.11},{"date":"2026-05-06","value":965500000000.0}]},"Y":{"period":"2026년","latest":3728816666666.67,"is_new":false,"series":[{"date":"2026-04-08","value":3818253846153.85},{"date":"2026-04-16","value":3786715384615.38},{"date":"2026-04-17","value":3782869230769.23},{"date":"2026-04-21","value":3786275000000.0},{"date":"2026-04-27","value":3743907692307.69},{"date":"2026-04-28","value":3745128571428.57},{"date":"2026-05-06","value":3728816666666.67}]}},"stk_flow":[{"date":"2026-05-08","외인":4022786000,"개인":-3023463000,"기관":-977264000},{"date":"2026-05-07","외인":3629485000,"개인":-1289417000,"기관":-2374670000},{"date":"2026-05-06","외인":5160657000,"개인":19537324000,"기관":-24851009000},{"date":"2026-05-04","외인":-16221568000,"개인":20564737000,"기관":-5330515000},{"date":"2026-04-30","외인":-4463826000,"개인":-5918085000,"기관":7942715000},{"date":"2026-04-29","외인":1499251000,"개인":-2183275000,"기관":-1036190000},{"date":"2026-04-28","외인":10496573000,"개인":-11991715000,"기관":1778827000}]}]}