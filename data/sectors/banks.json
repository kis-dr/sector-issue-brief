2023년 하청 공사 현장에서 사망사고가 발생하면서 안전관리 심사 대상에 포함된 바 있다.\n\n기타공공기관인 기업은행은 2023년 데이터센터 공사 현장에서 하청업체 근로자 사망사고가 발생해 중점관리기관으로 편입됐다.","url":"https://view.asiae.co.kr/article/2026050709041848819","published_at":"2026-05-07T11:17:00","sentiment":"negative","is_new":true}],"disclosures":[],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":965500000000.0,"is_new":false,"series":[{"date":"2026-04-07","value":979800000000.0},{"date":"2026-04-08","value":979166666666.6699},{"date":"2026-04-16","value":973333333333.3301},{"date":"2026-04-27","value":967500000000.0},{"date":"2026-04-28","value":971111111111.11},{"date":"2026-05-06","value":965500000000.0}]},"Y":{"period":"2026년","latest":3728816666666.67,"is_new":false,"series":[{"date":"2026-04-07","value":3830941666666.67},{"date":"2026-04-08","value":3818253846153.85},{"date":"2026-04-16","value":3786715384615.38},{"date":"2026-04-17","value":3782869230769.23},{"date":"2026-04-21","value":3786275000000.0},{"date":"2026-04-27","value":3743907692307.69},{"date":"2026-04-28","value":3745128571428.57},{"date":"2026-05-06","value":3728816666666.67}]}},"stk_flow":[{"date":"2026-05-07","외인":3629485000,"개인":-1289417000,"기관":-2374670000},{"date":"2026-05-06","외인":5160657000,"개인":19537324000,"기관":-24851009000},{"date":"2026-05-04","외인":-16221568000,"개인":20564737000,"기관":-5330515000},{"date":"2026-04-30","외인":-4463826000,"개인":-5918085000,"기관":7942715000},{"date":"2026-04-29","외인":1499251000,"개인":-2183275000,"기관":-1036190000},{"date":"2026-04-28","외인":10496573000,"개인":-11991715000,"기관":1778827000},{"date":"2026-04-27","외인":-2847741000,"개인":3701724000,"기관":-904406000}]},{"code":"138930","name":"BNK금융지주","market":"KSP","price":18200.0,"change_pct":0.39,"market_cap":5647952000600.0,"fwd_pe":5.8481655,"has_chart":true,"has_new":true,"news":[],"disclosures":[{"date":"2026-05-07T16:14:50","title":"주식등의대량보유상황보고서(약식)","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260507000611","is_new":true},{"date":"2026-05-04T17:27:29","title":"기업설