결이 가시화되고 있으며, HiMSEN 엔진 유지·보수 독점권 보유로 사실상 확정된 수주잔고로 평가됨","하이퍼스케일러들의 플로팅데이터센터(FDC) 수요 증가에 따라 중고선박 FDC 개조사업 진출 논의 중이며, 기존 FSU&FSRU 개조 경험으로 기술적 장벽이 낮아 친환경솔루션 부문의 새로운 성장동력으로 기대","KKR 오버행 리스크 해소, 2026년 영업이익률 18.0%·2027년 21.5% 전망 등 수익성 개선 지속, 높은 배당성향(약 64%)으로 하방 리스크 제한적이라는 판단 하에 목표주가 34만원으로 상향"],"is_new":false}],"consensus":{"Q":{"period":"2026년 2분기","latest":108100000000.0,"is_new":false,"series":[{"date":"2026-04-06","value":106760000000.0},{"date":"2026-04-14","value":106540000000.0},{"date":"2026-04-16","value":106440000000.0},{"date":"2026-04-23","value":108640000000.0},{"date":"2026-04-27","value":108600000000.0},{"date":"2026-04-30","value":108100000000.0}]},"Y":{"period":"2026년","latest":433912500000.0,"is_new":false,"series":[{"date":"2026-04-06","value":446987500000.0},{"date":"2026-04-09","value":444985714285.70996},{"date":"2026-04-14","value":439757142857.14},{"date":"2026-04-16","value":438442857142.86},{"date":"2026-04-23","value":440585714285.70996},{"date":"2026-04-27","value":435100000000.0},{"date":"2026-04-30","value":433912500000.0}]}},"stk_flow":[{"date":"2026-05-06","외인":14434586000,"개인":8748062000,"기관":-23749020000},{"date":"2026-05-04","외인":-15087531000,"개인":13858618000,"기관":1585390000},{"date":"2026-04-30","외인":-1778441000,"개인":-2585584000,"기관":4081414000},{"date":"2026-04-29","외인":-27330025000,"개인":16990921000,"기관":10543761000},{"date":"2026-04-28","외인":-22488352000,"개인":11916485000,"기관":9445720000},{"date":"2026-04-27","외인":-20125394000,"개인":-13926906000,"기관":34144133000},{"date":"2026-04-24","외인":-33034907000,"개인":-9304821000,"기관":42531393000}]},{"code":"017960","name":"한국카본","market":"KSP","price":47750.0,"change_pct":-2.15,"market_cap":2496303150000.0,"fwd_pe":16.965996,"has_chart":true,"has_new":false,"news":[],"disclosures":[],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":42175000000.0,"is_new":false,"series":[{"date":"2026-04-06","value":42175000000.0}]},"Y":{"period":"2026년","latest":163140000000.0,"is_new":false,"series":