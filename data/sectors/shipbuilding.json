[{"id":"1705341770117812514","title":"한화오션, 3632억 규모 LNG운반선 1척 수주","summary":"한화오션은 유럽 지역 선주로부터 3632억원 규모의 액화천연가스운반선(LNGC) 1척에 대한 공사를 수주했다고 11일 공시했다.\n\n계약 금액은 지난해 매출액의 2.8%에 해당하며, 계약 기간은 오는 2029년 6월15일까지다.","url":"https://www.hankyung.com/article/2026051184306","published_at":"2026-05-11T15:01:18","sentiment":"positive","is_new":true},{"id":"1705325540682109582","title":"\"대화 계속 거부하면 초기업 노조 전환\"…한화노협, 전면 투쟁 선포","summary":"정도영 한화갤러리아노동조합 위원장은 \"한화노협은 임금 규제 폐지와 정년 연장, 복리후생 확대 등 노동자들의 정당한 요구를 그룹에 전달했지만 아무런 답변도 받지 못했다\"며 \"노동자들의 요구를 무시하고 한화노협을 공식 대화 상대로 인정하지 않는다면 초기업 노조 출범도 검토하겠다\"고 밝혔다.\n\n현재 한화노협은 한화그룹 계열사 노조 협의체 형태인데 사측에서 노협을 대화의 파트너로 인정하지 않으니 이를 기업 노조 형태로 전환해 결속력을 강화하겠다는 방침이다.\n\n한화노협은 한화그룹이 공동요구안에 대한 직접 대화에 나서지 않을 경우 이날 기자회견을 기점으로 한화빌딩 앞 집회 투쟁을 계속해서 이어갈 계획이다.","url":"https://www.ddaily.co.kr/page/view/2026051113342501917","published_at":"2026-05-11T13:58:07","sentiment":"negative","is_new":true}],"disclosures":[{"date":"2026-05-11T10:09:02","title":"단일판매ㆍ공급계약체결              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260511800175","is_new":true},{"date":"2026-05-07T15:44:46","title":"기업설명회(IR)개최(안내공시)              ","url":"https://dart.fss.or.kr/dsaf001/main.do?rcpNo=20260507800582","is_new":false}],"reports":[],"consensus":{"Q":{"period":"2026년 2분기","latest":487183333333.32996,"is_new":false,"series":[{"date":"2026-04-13","value":429107692307.69},{"date":"2026-04-14","value":426028571428.56995},{"date":"2026-04-15","value":425960000000.0},{"date":"2026-04-16","value":436962500000.0},{"date":"2026-04-17","value":438241176470.58997},{"date":"2026-04-28","value":472960000000.0},{"date":"2026-04-29","value":476425000000.0},{"date":"2026-05-04","value":478657894736.84},{"date":"2026-05-06","value":487183333333.32996}]},"Y":{"period":"2026년","latest":1810215789473.68,"is_new":false,"series":[{"date":"2026-04-13","value":1716405555555.56},{"date":"2026-04-14","value":1686683333333.3298},{"date":"2026-04-15","value":1671127777777.78},{"date":"2026-04-16","val